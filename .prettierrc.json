{
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 120,
    "tabWidth": 4,
    "useTabs": false,
    "plugins": ["prettier-plugin-angular"],
    "overrides": [
        {
            "files": "*.html",
            "options": {
                "parser": "angular",
                "htmlWhitespaceSensitivity": "ignore",
                "bracketSameLine": true
            }
        }
    ]
}
